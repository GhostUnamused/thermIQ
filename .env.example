# ─── Core (required) ─────────────────────────────────────────────────────────
GEMINI_API_KEY=        # primary LLM (gemini-2.5-flash)
JINA_API_KEY=          # embeddings (jina-embeddings-v3) + web search (s.jina.ai)
QDRANT_URL=
QDRANT_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
INGEST_API_KEY=        # shared secret gating /api/ingest_document (must match X-Ingest-Key sent by docs/app.js)

# ─── Optional fallbacks (LLM cascade when gemini-2.5-flash is throttled) ──────
GEMINI_API_KEY2=       # optional extra Gemini key — doubles daily free quota
GEMINI_API_KEY3=       # optional extra Gemini key — triples daily free quota
NIM_API_KEY=           # NVIDIA NIM fallback (meta/llama-3.3-70b-instruct)
OPENROUTER_API_KEY=    # last-resort fallback; tries free models (llama-3.3-70b, deepseek-r1, nemotron)
